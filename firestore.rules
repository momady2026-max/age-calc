rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User document
    match /users/{userId} {
      allow read, write: if isOwner(userId) && isValidId(userId);

      // Folders subcollection
      match /folders/{folderId} {
        allow read, write: if isOwner(userId) && isValidId(folderId);
      }

      // Notes subcollection
      match /notes/{noteId} {
        allow read, write: if isOwner(userId) && isValidId(noteId);
      }

      // Safe Files subcollection
      match /safeFiles/{fileId} {
        allow read, write: if isOwner(userId) && isValidId(fileId);
      }
    }
  }
}
